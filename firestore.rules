rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Os eventos podem ser lidos por qualquer pessoa
    match /events/{eventId} {
      allow read: if true;
      // Os eventos só podem ser criados, atualizados ou eliminados por utilizadores autenticados
      allow write: if request.auth != null;
    }

    // As respostas culturais podem ser lidas e criadas por qualquer pessoa
    match /respostas_culturais/{responseId} {
      allow read, create: if true;
      // Apenas utilizadores autenticados podem modificá-las ou eliminá-las (por exemplo, para moderação)
      allow update, delete: if request.auth != null;
    }
  }
}
